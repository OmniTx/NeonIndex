# NeonIndex Configuration Template
# Copy this file to .env and customize your settings

# Admin password (CHANGE THIS!)
ADMIN_PASSWORD=your_secure_password_here

# Files to hide from public view (comma-separated)
HIDDEN_FILES=.env,admin.php,.htaccess,.git,comments.json,rate_limits.json,downloads.log

# Site title displayed in header
SITE_TITLE=NeonIndex

# Default theme: dark or light
DEFAULT_THEME=dark

# README position: top or bottom
README_POSITION=bottom

# Feature toggles (true/false)
SHOW_DOWNLOAD=true
SHOW_RENAME=true
SHOW_DELETE=true
SHOW_UPLOAD=true
SHOW_THEME_TOGGLE=true
SHOW_COMMENTS=true

# Upload & Rate Limiting
MAX_UPLOAD_SIZE=10           # Max file size in MB
RATE_LIMIT_UPLOADS=20        # Max uploads per IP per hour (0 = disabled)
RATE_LIMIT_COMMENTS=10       # Max comments per IP per hour (0 = disabled)
ENABLE_DOWNLOAD_LOG=false    # Log all downloads to downloads.log
